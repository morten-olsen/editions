---
/**
 * Site-wide navigation bar. Matches the magazine masthead visual language:
 * monospace brand mark, minimal, warm.
 */
type Props = {
  current?: string;
};

const { current } = Astro.props;

const guides = [
  { href: "/guides/getting-started", label: "Getting started" },
  { href: "/guides/sources", label: "Sources" },
  { href: "/guides/focuses", label: "Focuses" },
  { href: "/guides/editions", label: "Editions" },
  { href: "/guides/feed-and-voting", label: "Feed & voting" },
];
---

<nav class="sticky top-0 z-40 bg-surface/80 backdrop-blur-md border-b border-border">
  <div class="max-w-wide mx-auto px-6 md:px-12 lg:px-20">
    <div class="flex items-center justify-between h-14">
      <!-- Brand -->
      <a
        href="/"
        class="text-xs font-mono tracking-wide uppercase text-ink-faint hover:text-ink transition-colors duration-fast"
      >
        Editions
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-1">
        <a
          href="/"
          class:list={[
            "text-xs px-3 py-1.5 rounded-md transition-colors duration-fast",
            current === "home"
              ? "text-ink bg-surface-sunken"
              : "text-ink-tertiary hover:text-ink hover:bg-surface-sunken",
          ]}
        >
          Home
        </a>
        {guides.map((g) => (
          <a
            href={g.href}
            class:list={[
              "text-xs px-3 py-1.5 rounded-md transition-colors duration-fast",
              current === g.href
                ? "text-ink bg-surface-sunken"
                : "text-ink-tertiary hover:text-ink hover:bg-surface-sunken",
            ]}
          >
            {g.label}
          </a>
        ))}
        <span class="w-px h-4 bg-border mx-2" />
        <a
          href="https://github.com/morten-olsen/editions"
          class="text-xs text-ink-tertiary hover:text-ink transition-colors duration-fast px-2"
          target="_blank"
          rel="noopener"
        >
          GitHub
        </a>
      </div>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-toggle"
        class="md:hidden text-ink-tertiary hover:text-ink transition-colors duration-fast p-1 cursor-pointer"
        aria-label="Toggle menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="5" x2="15" y2="5" />
          <line x1="3" y1="9" x2="15" y2="9" />
          <line x1="3" y1="13" x2="15" y2="13" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface">
    <div class="px-6 py-4 flex flex-col gap-1">
      <a
        href="/"
        class:list={[
          "text-sm px-3 py-2 rounded-md transition-colors duration-fast",
          current === "home"
            ? "text-ink bg-surface-sunken"
            : "text-ink-secondary hover:text-ink hover:bg-surface-sunken",
        ]}
      >
        Home
      </a>
      <div class="text-[10px] font-mono tracking-wide uppercase text-ink-faint mt-3 mb-1 px-3">
        Guides
      </div>
      {guides.map((g) => (
        <a
          href={g.href}
          class:list={[
            "text-sm px-3 py-2 rounded-md transition-colors duration-fast",
            current === g.href
              ? "text-ink bg-surface-sunken"
              : "text-ink-secondary hover:text-ink hover:bg-surface-sunken",
          ]}
        >
          {g.label}
        </a>
      ))}
      <div class="h-px bg-border my-2" />
      <a
        href="https://github.com/morten-olsen/editions"
        class="text-sm text-ink-tertiary hover:text-ink transition-colors duration-fast px-3 py-2"
        target="_blank"
        rel="noopener"
      >
        GitHub
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
