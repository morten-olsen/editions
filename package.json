{
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "onnxruntime-node",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter @editions/server dev",
    "dev:web": "pnpm --filter @editions/web dev",
    "build": "pnpm --filter @editions/server build",
    "check": "pnpm --filter @editions/server check && pnpm --filter @editions/web check",
    "test": "vitest run"
  },
  "devDependencies": {
    "portless": "^0.5.2",
    "vitest": "^4.0.18",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.54.0"
  }
}
